# Database Configuration
MYSQL_DATABASE=planbookai
MYSQL_USER=root
MYSQL_PASSWORD=root

# Supabase & Storage Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=planbookai-storage

# Supabase S3 Compatibility (for StorageService/AWS SDK)
SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=your_supabase_s3_access_key
SUPABASE_S3_SECRET_KEY=your_secret_key

# AI Model API Keys
GEMINI_API_KEY=your_gemini_key